{
  "expo": {
    "name": "FinanzApp",
    "slug": "finanzapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2196F3"
    },
    "assetBundlePatterns": [
      "**/*",
      "assets/adaptive-icon.png"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.madlx.finanzapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.madlx.finanzapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "b9267b04-b353-4075-84bd-184d54f85572"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#ffffff",
          "defaultChannel": "reminders"
        }
      ]
    ]
  }
}
